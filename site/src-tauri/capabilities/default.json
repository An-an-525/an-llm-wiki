{
  "$schema": "../gen/schemas/desktop-schema.json",
  "capabilities": [
    {
      "identifier": "default",
      "description": "Shared capability set for An Study Room",
      "windows": [
        "main"
      ],
      "permissions": [
        "core:default",
        "opener:default",
        "process:default"
      ]
    },
    {
      "identifier": "desktop-updater",
      "description": "Desktop-only updater capability for An Study Room",
      "windows": [
        "main"
      ],
      "platforms": [
        "macOS",
        "windows",
        "linux"
      ],
      "permissions": [
        "updater:default"
      ]
    }
  ]
}
