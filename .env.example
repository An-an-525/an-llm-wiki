OBSIDIAN_VAULT_PATH=.

# Xiaoan local chat proxy. Keep real values in local environment variables or a private .env file.
XIAOAN_RELAY_BASE_URL=https://relay.example.com/v1
XIAOAN_RELAY_API_KEY=
XIAOAN_MODEL=deepseek-v4-pro
XIAOAN_REASONING_EFFORT=high
XIAOAN_SERVER_HOST=127.0.0.1
XIAOAN_SERVER_PORT=8788
XIAOAN_ALLOWED_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
